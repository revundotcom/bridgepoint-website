# ============================================================================
# Bridge Point Maintenance — Environment Variables
# ============================================================================
# Copy to .env.local for local development.
# NEXT_PUBLIC_* variables are inlined into the client bundle at build time
# and are visible to any browser visitor. Everything else is server only.
# ============================================================================

# ─── Maps (client side) ─────────────────────────────────────────────────────
# Google Maps JavaScript API key. Restrict in GCP to HTTP referrers for the
# production domain only.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=


# ─── Build time image generation scripts (server only) ──────────────────────
# Google Generative AI / Imagen 4 key used by scripts/generate-imagen.py and
# the other generate-*.py scripts. Get one at https://aistudio.google.com/apikey
GOOGLE_GENAI_API_KEY=
